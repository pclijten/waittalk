{
  "rules": {
    "active_users": {
      "$uid": {
        ".read":  "auth != null",
        ".write": "auth != null && (auth.uid === $uid || data.child('matched').val() === false)"
      }
    },
    "chats": {
      "$chatId": {
        ".read":  "auth != null",
        ".write": "auth != null",
        "messages": {
          "$msgId": {
            ".validate": "newData.hasChildren(['text','sender','name','ts']) && newData.child('text').isString() && newData.child('text').val().length <= 500"
          }
        }
      }
    }
  }
}
